# Copy to .env (do not commit .env)
#
# Ports (host -> container)
MONGODB_PORT=27017
REDIS_PORT=6379
KAFKA_PORT=9092
ELASTICSEARCH_PORT=9200
LOGSTASH_PORT=5044
KIBANA_PORT=5601

GATEWAY_PORT=8080
INGESTION_PORT=8081
PARSER_PORT=8082
RISK_ENGINE_PORT=8083
LLM_PORT=8084
ALERT_PORT=8085
REPORT_PORT=8086
DASHBOARD_PORT=3000

# LLM service configuration
LLM_PROVIDER=openai
LLM_API_KEY=replace_me
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Gateway / security
JWT_PUBLIC_KEY_PATH=classpath:keys/public.pem
RATE_LIMIT_REPLENISH=10
RATE_LIMIT_BURST=20

# Risk engine tuning
FAILED_LOGIN_WINDOW_MINUTES=60
FAILED_LOGIN_THRESHOLD=5
GEO_ANOMALY_LOOKBACK_DAYS=30

# Phase 2 — new services
PII_DETECTOR_PORT=8090
ENRICHMENT_PORT=8091
NOTIFICATION_PORT=8092
GEO_IP_URL=http://ip-api.com/json
SLACK_WEBHOOK_URL=

