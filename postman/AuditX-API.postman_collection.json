    {
      "name": "📥 Ingestion — REST API",
      "item": [
        {
          "name": "Ingest Raw Event (Key=Value)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payload\": \"timestamp=2024-06-01T12:00:00Z userId=alice action=LOGIN sourceIp=192.168.1.10 tenantId={{tenant_id}} outcome=SUCCESS\",\n  \"payloadType\": \"RAW\",\n  \"idempotencyKey\": \"postman-kv-001\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_ingestion}}/api/events/raw",
              "host": ["{{base_ingestion}}"],
              "path": ["api", "events", "raw"]
            }
          }
        },
        {
          "name": "Ingest JSON Event",
          "request": {
            "method": "POST",
